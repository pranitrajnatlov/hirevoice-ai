*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
.eggs/
dist/
build/
*.whl
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
.venv/
venv/
env/
ENV/

# ========================
# Runtime data — generated at runtime, not source
# ========================
data/audio/*
data/sessions/*
data/piper_models/*

# Keep placeholder files so git tracks the empty dirs
!data/audio/.gitkeep
!data/sessions/.gitkeep
!data/piper_models/.gitkeep

# SQLite databases
*.db
*.sqlite3

